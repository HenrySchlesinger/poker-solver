set_pot 100
set_effective_stack 950
set_board Jh,Th,9c,8h,7c
set_range_ip QQ,KK,AA,AQs,AKs,KQs,AJs,ATs,KJs,KTs,QJs,QTs,JTs,88,AJo,AQo,AKo,KQo,KJo
set_range_oop JJ,TT,99,88,AJs,ATs,KJs,KTs,QJs,QTs,JTs,AQs,AKs,KQs,AJo,ATo,KJo,KTo,QJo,QTo,JTo
set_bet_sizes oop,river,bet,33,66,100,200
set_bet_sizes oop,river,raise,33,66,100,200
set_bet_sizes oop,river,allin
set_bet_sizes ip,river,bet,33,66,100,200
set_bet_sizes ip,river,raise,33,66,100,200
set_bet_sizes ip,river,allin
set_allin_threshold 0.67
build_tree
set_thread_num 16
set_accuracy 0.3
set_max_iteration 1000
set_print_interval 10
set_use_isomorphism 1
start_solve
set_dump_rounds 2
dump_result target/tsconfig/spot_016.result.json
