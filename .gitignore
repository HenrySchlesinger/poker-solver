# Rust build
target/
**/*.rs.bk
Cargo.lock.bak

# OS
.DS_Store
*.swp

# Precomputed artifacts — do NOT commit these; they're generated
# offline (locally or on Colab) and distributed separately.
data/preflop-ranges/*.bin
data/preflop-ranges/*.json
data/iso-tables/*.bin
data/flop-cache/*.bin
data/flop-cache/*.json
!data/**/.gitkeep
!data/**/README.md
# v0.1 format-only seed ships committed (see data/flop-cache/README.md).
# Real cache binaries from Colab precompute stay ignored.
!data/flop-cache/flop-cache-v0.1.bin

# IDE
.idea/
.vscode/
*.iml

# Bench output
criterion/
flamegraph.svg
perf.data*

# Colab
colab/**/*.ipynb_checkpoints/

# TexasSolver differential-testing artifacts (see docs/DIFFERENTIAL_TESTING.md).
# The binary is AGPL; we build it locally and use it as a test oracle but
# never commit it or its source tree.
bin/
vendor/TexasSolver/
