set_pot 100
set_effective_stack 950
set_board 9h,8h,7c,6d,5s
set_range_ip TT,JJ,QQ,KK,AA,AQs,AKs,KQs,AJs,ATs,QJs,QTs,JTs,AJo,AQo,AKo,KQo,KJo,KTo,QJo,QTo,JTo
set_range_oop TT,JJ,QQ,KK,AA,AQs,AKs,KQs,AJs,ATs,QJs,QTs,JTs,AJo,AQo,AKo,KQo,KJo,KTo,QJo,QTo,JTo
set_bet_sizes oop,river,bet,33,66,100,200
set_bet_sizes oop,river,raise,33,66,100,200
set_bet_sizes oop,river,allin
set_bet_sizes ip,river,bet,33,66,100,200
set_bet_sizes ip,river,raise,33,66,100,200
set_bet_sizes ip,river,allin
set_allin_threshold 0.67
build_tree
set_thread_num 16
set_accuracy 0.3
set_max_iteration 1000
set_print_interval 10
set_use_isomorphism 1
start_solve
set_dump_rounds 2
dump_result target/tsconfig/spot_017.result.json
